{
  "expo": {
    "name": "Controller",
    "slug": "controller",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "controllertest",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vvaibhavv3434.controller-test"
    },
    "android": {
      "permissions": [
        "INTERNET"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vvaibhavv3434.controller_test"
    },
    "plugins": [
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
